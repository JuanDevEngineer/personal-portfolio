# Server
PORT=3001

# Gmail SMTP
# Para usar Gmail necesitas generar un "App Password":
# 1. Ve a https://myaccount.google.com/security
# 2. Activa la verificación en 2 pasos
# 3. Busca "App Passwords" y genera una para "Mail"
# 4. Copia la contraseña de 16 caracteres aquí

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=your_app_password_here

# Destinatario
MAIL_TO=

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000
